{
  "name": "autoform",
  "description": "Turn any AI coding assistant into a Lean 4 formalization agent. Mathlib conventions, proof strategies, review checklists, and statement extraction — distilled from 94k PR reviews.",
  "version": "0.1.0",
  "author": {
    "name": "Vivien Cabannes",
    "url": "https://github.com/vivc"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start\"",
            "timeout": 5,
            "statusMessage": "Loading AutoForm context"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "autoform-workspace": {
      "command": "python",
      "args": ["-m", "servers.workspace.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Workspace inspection — scan project structure, sorry/axiom counts, targets"
    },
    "autoform-repl": {
      "command": "python",
      "args": ["-m", "servers.repl.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Lean 4 REPL — run code, verify proofs, check compilation"
    },
    "autoform-mathlib": {
      "command": "python",
      "args": ["-m", "servers.mathlib.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Mathlib source search — grep, find by name, read files"
    },
    "autoform-lsp": {
      "command": "python",
      "args": ["-m", "servers.lsp.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Lean 4 LSP — file diagnostics and type information"
    },
    "autoform-trace": {
      "command": "python",
      "args": ["-m", "servers.trace.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "AUTOFORM_TRACE_DIR": "${AUTOFORM_TRACE_DIR:-./traces}"
      },
      "description": "Execution tracing — record proof attempts, steps, reviews"
    },
    "autoform-aristotle": {
      "command": "python",
      "args": ["-m", "servers.aristotle.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "ARISTOTLE_DOWNLOAD_DIR": "${ARISTOTLE_DOWNLOAD_DIR:-./aristotle-output}"
      },
      "description": "Aristotle (Harmonic) — delegate formalization to an autonomous prover"
    }
  }
}
