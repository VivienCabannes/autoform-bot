{
  "name": "autoform",
  "description": "Lean 4 formalization agent: Mathlib conventions, proof strategies, review, statement extraction, and textbook-to-blueprint formalization planning.",
  "version": "0.3.0",
  "author": {
    "name": "Vivien Cabannes",
    "url": "https://github.com/facebookresearch/autoform-bot"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit\"",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "lean-informal-planner-mathlib": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/run-mathlib-server.sh"],
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-${CLAUDE_PROJECT_DIR}}"
      },
      "description": "Mathlib search for the formalization planner"
    },
    "autoform-repl": {
      "command": "uv",
      "args": ["run", "--extra", "repl", "python", "-m", "servers.repl.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Lean 4 REPL — run code, verify proofs, check compilation"
    },
    "autoform-lsp": {
      "command": "uv",
      "args": ["run", "python", "-m", "servers.lsp.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Lean 4 LSP — file diagnostics and type information"
    },
    "autoform-aristotle": {
      "command": "uv",
      "args": ["run", "--extra", "aristotle", "python", "-m", "servers.aristotle.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "ARISTOTLE_DOWNLOAD_DIR": "${ARISTOTLE_DOWNLOAD_DIR:-./aristotle-output}"
      },
      "description": "Aristotle (Harmonic) — delegate formalization to an autonomous prover"
    },
    "autoform-zulip": {
      "command": "uv",
      "args": ["run", "--extra", "zulip", "python", "-m", "servers.zulip.server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-.}"
      },
      "description": "Zulip search — find community discussions about naming, proofs, and prior art"
    }
  }
}
