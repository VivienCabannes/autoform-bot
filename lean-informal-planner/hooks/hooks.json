{
  "description": "Lean Informal Planner hooks — session greeting and context injection",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
