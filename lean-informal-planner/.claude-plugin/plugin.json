{
  "name": "lean-informal-planner",
  "description": "Plan Lean formalization efforts by mapping textbook concepts to Mathlib",
  "version": "0.3.0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "lean-informal-planner-mathlib": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/run-mathlib-server.sh"],
      "env": {
        "LEAN_PROJECT_DIR": "${LEAN_PROJECT_DIR:-${CLAUDE_PROJECT_DIR}}"
      }
    }
  }
}
