#!/usr/bin/env bash
# SessionStart hook — introduce the Lean Informal Planner plugin.
# Silent-fails on all errors (never blocks session start).

set -euo pipefail

context="The Lean Informal Planner plugin is active. This plugin helps plan Lean 4 formalization efforts by building a tiered dependency graph from textbooks — coarse concept clusters first, then fine definitions and statements with their own paraphrased content — mapping it to Mathlib and rendering it as an interactive blueprint. When the user first interacts, introduce the plugin briefly and ask which textbook(s) to analyze (LaTeX, Markdown, or PDF) and which concepts or chapters are the formalization targets. Available skills: /lean-informal-planner:plan (the full two-phase planning pipeline) and /lean-informal-planner:plan-view (build and open the interactive blueprint, with a tier toggle)."

escape_for_json() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

escaped_context="$(escape_for_json "$context")"
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped_context"
