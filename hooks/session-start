#!/usr/bin/env bash
# SessionStart hook — inject autoform context into the session.
# Silent-fails on all errors (never blocks session start).

set -euo pipefail

context="AutoForm Bot plugin is available. For Lean 4 or Mathlib formalization tasks, use the plugin skills: /autoform (conventions), /autoform-prove (strategies), /autoform-review (review), /autoform-quality (style), /autoform-extract (statement extraction), /autoform-crew (parallel orchestration). Inspect the workspace before editing, search Mathlib before proving from scratch, do not introduce axioms or sorry as a shortcut, and verify with Lean REPL or LSP before reporting completion."

escape_for_json() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

escaped_context="$(escape_for_json "$context")"
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped_context"
